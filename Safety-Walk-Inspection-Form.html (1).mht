.time-field input { flex: 1 1 0%; }

.now-btn { padding: 10px 12px; border-radius: var(--radius); border: 2px solid var(--severity-low); background: oklch(0.96 0.02 145); color: var(--severity-low); font-family: inherit; font-size: 0.75rem; font-weight: 700; cursor: pointer; touch-action: manipulation; white-space: nowrap; }

.now-btn:active { transform: scale(0.95); }

