.voice-input input, .voice-input textarea { flex: 1 1 0%; }

.voice-input textarea { min-height: 100px; resize: vertical; }

.mic-btn { width: 48px; height: 48px; min-width: 48px; border-radius: 50%; border: 2px solid var(--border); background: var(--surface); cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; touch-action: manipulation; }

.mic-btn.recording { border-color: var(--severity-critical); background: oklch(0.95 0.03 15); animation: 1s ease 0s infinite normal none running pulse; }

.mic-btn svg { width: 20px; height: 20px; stroke: currentcolor; fill: none; stroke-width: 2; }

.main-form { max-width: 500px; margin: 0px auto; display: flex; flex-direction: column; gap: 16px; }

.section-divider { height: 1px; background: var(--border); margin: 16px 0px; }

.section-title { font-size: 1.1rem; font-weight: 700; padding-top: 8px; display: flex; align-items: center; justify-content: space-between; }

.section-title .count-badge { background: var(--primary-surface); color: var(--primary); font-size: 0.8rem; font-weight: 700; padding: 4px 10px; border-radius: 20px; }

.findings-summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 12px; }

.stat-pill { text-align: center; padding: 10px 4px; border-radius: 10px; background: var(--surface); border: 1px solid var(--border); }

.stat-pill .count { font-size: 1.5rem; font-weight: 800; font-variant-numeric: tabular-nums; }

.stat-pill .label { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; color: var(--text-secondary); }

.stat-pill.low .count { color: var(--severity-low); }

.stat-pill.medium .count { color: var(--severity-medium); }

.stat-pill.high .count { color: var(--severity-high); }

.stat-pill.critical .count { color: var(--severity-critical); }

.findings-list { display: flex; flex-direction: column; gap: 12px; margin-top: 12px; }

.finding-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; display: flex; gap: 12px; align-items: flex-start; cursor: pointer; }

.finding-card:active { transform: scale(0.98); }

.finding-thumb { width: 56px; height: 56px; border-radius: 8px; background: var(--primary-surface); flex-shrink: 0; overflow: hidden; display: flex; align-items: center; justify-content: center; }

.finding-thumb img { width: 100%; height: 100%; object-fit: cover; }

.finding-thumb .no-photo { font-size: 0.65rem; color: var(--text-secondary); }

.finding-info { flex: 1 1 0%; min-width: 0px; }

.finding-info h4 { font-size: 0.9rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.finding-info p { font-size: 0.8rem; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }

.finding-meta { display: flex; gap: 6px; margin-top: 6px; flex-wrap: wrap; }

.finding-meta .tag { font-size: 0.65rem; font-weight: 600; padding: 2px 8px; border-radius: 6px; background: var(--primary-surface); color: var(--primary); }

.finding-meta .tag.assignee { background: oklch(0.92 0.02 145); color: oklch(0.35 0.12 145); }

.finding-meta .tag.due { background: oklch(0.92 0.02 30); color: oklch(0.4 0.12 30); }

.severity-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; margin-top: 6px; }

.severity-dot.low { background: var(--severity-low); }

.severity-dot.medium { background: var(--severity-medium); }

.severity-dot.high { background: var(--severity-high); }

.severity-dot.critical { background: var(--severity-critical); animation: 1.5s ease 0s infinite normal none running pulse; }

.empty-state { text-align: center; padding: 40px 24px; color: var(--text-secondary); }

.empty-state .icon { font-size: 2.5rem; margin-bottom: 8px; opacity: 0.5; }

.empty-state p { font-size: 0.85rem; }

.btn { font-family: inherit; font-size: 1rem; font-weight: 600; padding: 16px 24px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: var(--radius); cursor: pointer; touch-action: manipulation; }

.btn:active { transform: scale(0.97); }

.btn:disabled { opacity: 0.5; pointer-events: none; }

.btn-primary { background: var(--primary); color: oklch(0.98 0.005 255); }

.btn-danger { background: oklch(0.95 0.03 15); color: var(--severity-critical); }

.btn-full { width: 100%; }

.btn-add { display: flex; align-items: center; justify-content: center; gap: 8px; background: var(--primary-surface); color: var(--primary); border: 2px dashed oklch(0.75 0.06 255); padding: 18px; width: 100%; margin-top: 12px; }

.btn-add .plus { font-size: 1.25rem; font-weight: 700; }

.btn-print { display: flex; align-items: center; justify-content: center; gap: 8px; background: var(--surface); color: var(--text); border: 1px solid var(--border); padding: 14px; width: 100%; margin-top: 8px; font-size: 0.9rem; }

.btn-no-findings { display: flex; align-items: center; justify-content: center; gap: 8px; background: var(--surface); color: var(--severity-low); border: 2px solid var(--severity-low); padding: 16px; width: 100%; margin-top: 8px; font-size: 0.9rem; font-weight: 600; border-radius: var(--radius); }

.complete-section { margin-top: 8px; display: flex; flex-direction: column; gap: 16px; }

.signature-pad { width: 100%; height: 150px; border: 2px solid var(--border); border-radius: var(--radius); background: var(--surface); touch-action: none; cursor: crosshair; }

.sig-actions { display: flex; justify-content: space-between; margin-top: 8px; align-items: center; }

.sig-actions button { font-family: inherit; font-size: 0.8rem; font-weight: 600; color: var(--primary); background: none; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; cursor: pointer; padding: 8px 12px; }

.sig-name { font-size: 0.85rem; font-weight: 500; color: var(--text-secondary); font-style: italic; }

.nav-back { display: flex; align-items: center; gap: 8px; font-size: 0.9rem; font-weight: 600; color: var(--primary); background: none; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; cursor: pointer; padding: 8px 0px; }

.finding-form { max-width: 400px; margin: 0px auto; display: flex; flex-direction: column; gap: 20px; padding-top: 12px; }

.photo-section { display: flex; flex-direction: column; gap: 10px; }

.photo-buttons { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

.photo-btn { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 14px 12px; border-radius: var(--radius); border: 2px solid var(--border); background: var(--surface); font-family: inherit; font-size: 0.85rem; font-weight: 600; color: var(--text); cursor: pointer; }

.photo-btn:active { transform: scale(0.96); }

.photo-btn .icon { font-size: 1.2rem; }

.photo-gallery { display: flex; gap: 8px; overflow-x: auto; padding: 4px 0px; }

.photo-gallery .thumb { width: 72px; height: 72px; border-radius: 8px; overflow: hidden; flex-shrink: 0; position: relative; }

.photo-gallery .thumb img { width: 100%; height: 100%; object-fit: cover; }

.photo-gallery .thumb .remove-photo { position: absolute; top: 3px; right: 3px; width: 22px; height: 22px; border-radius: 50%; background: oklch(0.2 0.01 255 / 0.75); color: white; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; font-size: 0.75rem; display: flex; align-items: center; justify-content: center; cursor: pointer; }

.photo-gallery .thumb .edit-photo { position: absolute; bottom: 3px; left: 3px; width: 22px; height: 22px; border-radius: 50%; background: oklch(0.4 0.15 255 / 0.85); color: white; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; font-size: 0.6rem; display: flex; align-items: center; justify-content: center; cursor: pointer; }

.photo-count { font-size: 0.75rem; color: var(--text-secondary); }

.photo-hint { font-size: 0.7rem; color: var(--text-secondary); font-style: italic; margin-top: 2px; }

.severity-picker, .priority-picker { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }

.severity-option, .priority-option { padding: 12px 4px; border: 2px solid var(--border); border-radius: 10px; text-align: center; cursor: pointer; touch-action: manipulation; }

.severity-option .dot { width: 12px; height: 12px; border-radius: 50%; margin: 0px auto 6px; }

.severity-option .name, .priority-option .name { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; }

.priority-option .icon { font-size: 1rem; margin-bottom: 4px; }

.severity-option.low .dot { background: var(--severity-low); }

.severity-option.medium .dot { background: var(--severity-medium); }

.severity-option.high .dot { background: var(--severity-high); }

.severity-option.critical .dot { background: var(--severity-critical); }

.severity-option.selected, .priority-option.selected { border-color: var(--primary); background: var(--primary-surface); }

.toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); cursor: pointer; }

.toggle-row span { font-size: 0.9rem; font-weight: 500; }

.toggle { width: 48px; height: 28px; border-radius: 14px; background: var(--border); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; position: relative; pointer-events: none; }

.toggle::after { content: ""; position: absolute; width: 22px; height: 22px; border-radius: 50%; background: white; top: 3px; left: 3px; transition: transform 200ms var(--ease-out); box-shadow: oklch(0 0 0 / 0.2) 0px 1px 3px; }

.toggle.on { background: var(--primary); }

.toggle.on::after { transform: translateX(20px); }

.assignment-section { background: var(--primary-surface); border-radius: var(--radius); padding: 16px; display: flex; flex-direction: column; gap: 14px; }

.assignment-section .section-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--primary); }

.assignee-chips { display: flex; flex-wrap: wrap; gap: 8px; }

.assignee-chip { padding: 10px 16px; border-radius: 20px; border: 2px solid var(--border); font-size: 0.85rem; font-weight: 600; cursor: pointer; user-select: none; background: var(--surface); color: var(--text); }

.assignee-chip.selected { background: var(--primary); color: oklch(0.98 0.005 255); border-color: var(--primary); }

.finding-actions { display: flex; gap: 12px; margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--border); }

.finding-actions .btn { flex: 1 1 0%; }

.sync-progress { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin-top: 12px; }

.sync-progress .sync-title { font-size: 0.85rem; font-weight: 700; margin-bottom: 8px; }

.sync-progress .sync-log { font-size: 0.8rem; color: var(--text-secondary); max-height: 200px; overflow-y: auto; }

.sync-progress .sync-log div { padding: 3px 0px; }

.sync-progress .sync-log .success { color: var(--severity-low); }

.sync-progress .sync-log .error { color: var(--severity-critical); }

.toast { position: fixed; bottom: 40px; left: 50%; transform: translateX(-50%) translateY(100px); background: var(--text); color: var(--bg); padding: 12px 20px; border-radius: 10px; font-size: 0.85rem; font-weight: 500; opacity: 0; transition: all 300ms var(--ease-out); z-index: 100; white-space: nowrap; max-width: 90%; }

.toast.show { opacity: 1; transform: translateX(-50%) translateY(0px); }

.saved-count { font-size: 0.8rem; color: var(--text-secondary); text-align: center; padding: 8px; }

.emp-sig-section { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; display: flex; flex-direction: column; gap: 10px; }

.emp-sig-section .optional-label { font-size: 0.7rem; color: var(--text-secondary); font-style: italic; }

.annotate-overlay { display: none; position: fixed; inset: 0px; background: oklch(0.1 0.01 255 / 0.97); z-index: 200; flex-direction: column; }

.annotate-overlay.open { display: flex; }

.annotate-toolbar { display: flex; gap: 6px; padding: 10px 12px; background: oklch(0.15 0.01 255); align-items: center; justify-content: space-between; flex-wrap: wrap; }

.annotate-tools { display: flex; gap: 5px; }

.annotate-tools button { padding: 7px 10px; border-radius: 8px; border: 2px solid oklch(0.4 0.01 255); background: oklch(0.25 0.01 255); color: white; font-size: 0.7rem; font-weight: 600; cursor: pointer; }

.annotate-tools button.active { border-color: rgb(255, 59, 48); background: rgb(255, 59, 48); }

.annotate-actions { display: flex; gap: 6px; }

.annotate-actions button { padding: 7px 14px; border-radius: 8px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; font-size: 0.8rem; font-weight: 600; cursor: pointer; }

.annotate-actions .cancel-btn { background: oklch(0.3 0.01 255); color: white; }

.annotate-actions .save-btn { background: rgb(52, 199, 89); color: white; }

.annotate-canvas-wrap { flex: 1 1 0%; display: flex; align-items: center; justify-content: center; padding: 8px; overflow: hidden; }

.annotate-canvas-wrap canvas { max-width: 100%; max-height: 100%; touch-action: none; }

.annotate-text-bar { display: none; padding: 8px 12px; background: oklch(0.2 0.01 255); gap: 6px; align-items: center; flex-wrap: wrap; }

.annotate-text-bar.visible { display: flex; }

.annotate-text-bar input { flex: 1 1 0%; min-width: 100px; padding: 9px 12px; border-radius: 8px; border: 2px solid oklch(0.5 0.01 255); background: oklch(0.12 0.01 255); color: white; font-size: 0.9rem; font-family: inherit; }

.annotate-text-bar input:focus { outline: none; border-color: rgb(255, 59, 48); }

.annotate-text-bar .place-btn { padding: 9px 14px; border-radius: 8px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; background: rgb(255, 59, 48); color: white; font-weight: 700; font-size: 0.8rem; cursor: pointer; }

.size-btns { display: flex; gap: 4px; }

.size-btns button { width: 30px; height: 30px; border-radius: 6px; border: 2px solid oklch(0.4 0.01 255); background: oklch(0.25 0.01 255); color: white; font-weight: 700; cursor: pointer; font-size: 0.7rem; }

.size-btns button.active { border-color: rgb(255, 59, 48); background: rgb(255, 59, 48); }

.annotate-hint { padding: 4px 12px; background: oklch(0.18 0.01 255); font-size: 0.65rem; color: oklch(0.7 0.01 255); text-align: center; }

@media (min-width: 500px) {
  .screen { padding: 24px; max-width: 500px; margin: 0px auto; }
}
