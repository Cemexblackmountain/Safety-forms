* { margin: 0px; padding: 0px; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

:root { --primary: oklch(42% 0.14 255); --primary-surface: oklch(95% 0.02 255); --bg: oklch(98% 0.005 255); --surface: oklch(99% 0.003 255); --text: oklch(18% 0.015 255); --text-secondary: oklch(45% 0.02 255); --border: oklch(88% 0.01 255); --severity-low: oklch(55% 0.15 145); --severity-medium: oklch(65% 0.18 85); --severity-high: oklch(55% 0.2 30); --severity-critical: oklch(45% 0.22 15); --ease-out: cubic-bezier(0.22,1,0.36,1); --radius: 12px; }

html, body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; font-size: 16px; line-height: 1.5; background: var(--bg); color: var(--text); min-height: 100dvh; overflow-x: hidden; }

.screen { display: none; min-height: 100dvh; padding: 16px 16px 40px; animation: fadeIn 300ms var(--ease-out); }

.screen.active { display: block; }

@keyframes fadeIn { 
